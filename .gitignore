**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Coverage
.coverage
coverage/
htmlcov/

# Logs
*.log
