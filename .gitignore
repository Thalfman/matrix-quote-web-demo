# Claude Code local state — never commit agent definitions, skills, or settings
CLAUDE.md
.claude/

# Runtime data (mirrors matrix_quote_app/.gitignore)
data/master/*
!data/master/.gitkeep
models/*
!models/.gitkeep

# Streamlit-only artifacts accidentally copied into this repo — not used here.
quote_app.py
core/ui.py

# Environment
.env
.env.local
.env.*.local

# Build outputs
frontend/dist/
frontend/node_modules/
frontend/.vite/
frontend/*.tsbuildinfo
frontend/tailwind.config.js
frontend/tailwind.config.d.ts
frontend/vite.config.js
frontend/vite.config.d.ts

# Demo site static assets — regenerated by scripts/build_demo_static.py on every Vercel build
frontend/public/demo-assets/

